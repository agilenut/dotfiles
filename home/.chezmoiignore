# Chezmoi ignore file
# See https://www.chezmoi.io/reference/special-files-and-directories/chezmoiignore/

# macOS-specific files - ignore on non-macOS
{{ if ne .chezmoi.os "darwin" }}
.claude/
.config/alacritty/
.config/karabiner/
.config/qlmarkdown/
.config/syntax-highlight/
.config/zsh/zshrc.d/macos.zsh
.hushlogin
{{ end }}


# Secondary git identity - ignore if not configured
{{ if not (and (hasKey . "github") (hasKey .github "sc")) }}
.config/git/config-sc
{{ end }}

# Recap skill config — local-only (contains client repo paths, treat as
# sensitive). Belt-and-braces so an accidental `chezmoi add` doesn't land
# it in the dotfiles repo.
.claude/skills/recap/recap.toml

# LaunchAgents — macOS-only (~/Library/LaunchAgents has no analogue elsewhere)
{{ if ne .chezmoi.os "darwin" }}
Library/LaunchAgents/
{{ end }}

# Encrypted SSH config snippets — skip when no age private key exists
# locally (e.g. CI, fresh machine before age-keygen / fetch-chezmoi-age-key).
# Without this, chezmoi would try to decrypt with a missing identity and
# fail apply.
#
# Notes:
# - `chezmoi.config.encryption` always reads as "age" on machines with
#   encrypted source files (chezmoi auto-detects). So check for the
#   identity FILE existing instead — that's the reliable "do we actually
#   have a key?" signal.
# - The pattern uses the `.age`-suffixed path. For encrypted files,
#   chezmoi matches .chezmoiignore against the source-derived name (with
#   .age) at decrypt-decision time, not the destination name.
{{ if not (stat .chezmoi.config.age.identity) }}
.ssh/config.d/personal.conf.age
.ssh/config.d/tack.conf.age
{{ end }}

# Windows-specific ignores
{{ if eq .chezmoi.os "windows" }}
# No native zsh
.zshenv
.config/zsh/
.local/bin/fzf-preview
.local/bin/is-completion-fzf
.local/bin/is-completion-zsh
.local/bin/is-macos
{{ end }}
