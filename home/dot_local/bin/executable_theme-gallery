#!/usr/bin/env bash
# Generate a visual gallery of every themed tool rendering the sample files,
# once per palette theme. Output:
#   docs/theme-gallery/<theme>.html      committed, diffable (inline-styled)
#   docs/theme-gallery/ql/<sample>.png   local-only (gitignored), best-effort
#
# Mutates the active theme (via `theme <name>`) to render each, restoring the
# original on exit. Run after touching palette/theme files, then review the
# HTML before committing (see .claude/CLAUDE.md).
#
# Terminal tools (bat, delta, nvim, lazygit) are captured as ANSI and piped
# through aha to inline-styled HTML so the pages line-diff across changes.
# quicklook reflects the theme currently selected in the Syntax Highlight app
# (GUI state), so its PNGs are approximate and local-only.
set -euo pipefail

lib="$HOME/.local/lib/theme-gallery"
samples_dir="$lib/samples"
fixture_gen="$lib/make-lazygit-fixture"

for dep in aha tmux bat delta nvim highlight theme chezmoi jq; do
  command -v "$dep" >/dev/null || {
    echo "theme-gallery: missing dependency '$dep'" >&2
    exit 1
  }
done

repo="$(dirname "$(chezmoi source-path)")"
outdir="$repo/docs/theme-gallery"
mkdir -p "$outdir"

original="$(chezmoi data | jq -r '.theme // "vscode-dark-modern"')"
sock="theme-gallery-$$"

cleanup() {
  tmux -L "$sock" kill-server 2>/dev/null || true
  theme "$original" >/dev/null 2>&1 || true
}
# INT/TERM too, so an interrupt or kill still restores the theme (EXIT alone
# doesn't fire on a signal).
trap cleanup EXIT INT TERM

readonly COLS=140 ROWS=48

# Run $cmd in a sized detached tmux pane, wait $wait s, send any nav keys, then
# print the pane as ANSI. Isolated on a private socket. Never aborts the run.
tcapture() {
  local cmd=$1 wait=$2
  shift 2
  tmux -L "$sock" new-session -d -s g -x "$COLS" -y "$ROWS" "$cmd" 2>/dev/null || return 0
  sleep "$wait"
  local key
  for key in "$@"; do
    tmux -L "$sock" send-keys -t g -- "$key" 2>/dev/null || true
    sleep 0.5
  done
  tmux -L "$sock" capture-pane -t g -e -p 2>/dev/null || true
  tmux -L "$sock" kill-session -t g 2>/dev/null || true
}

# nvim capture that waits until the pane stabilises (two identical consecutive
# captures) so LSP and treesitter finish loading before we snapshot — no
# transient progress spinners or parser-install messages, which vary run to run
# (cold-cache noise). Keeps the settled state (semantic tokens, diagnostics),
# so those real colors show. Bounded; falls back to the last capture at timeout.
# Trim trailing blank rows (empty, or only spaces/tildes after stripping ANSI).
trim_trailing_blank() {
  awk -v esc="$(printf '\033')" '
    { line[NR] = $0; s = $0; gsub(esc "\\[[0-9;]*m", "", s); gsub(/[ ~]/, "", s); if (s != "") last = NR }
    END { for (i = 1; i <= last; i++) print line[i] }'
}

ncapture() {
  local file=$1 init=${2:-} prev="" cur="" launch
  if [[ -n $init ]]; then
    launch="nvim -n -S '$init' '$file'"
  else
    launch="nvim -n '$file'"
  fi
  tmux -L "$sock" new-session -d -s g -x "$COLS" -y "$ROWS" "$launch" 2>/dev/null || return 0
  # Require several consecutive identical captures, not just one — async layers
  # (LSP semantic tokens, gitsigns) land after a brief lull, and a single-match
  # break would snapshot the pre-token state (nondeterministic). A longer stable
  # window waits past token/sign arrival to the settled end-state.
  local same=0
  for _ in $(seq 1 25); do
    sleep 1
    cur="$(tmux -L "$sock" capture-pane -t g -e -p 2>/dev/null || true)"
    if [[ -n $cur && $cur == "$prev" ]]; then
      same=$((same + 1))
      ((same >= 4)) && break
    else
      same=0
    fi
    prev="$cur"
  done
  tmux -L "$sock" kill-session -t g 2>/dev/null || true
  # Drop the bottom chrome — statusline, cmdline, and fidget's bottom-right LSP
  # progress toast (all nondeterministic) — then trim trailing blank rows. The
  # buffer content sits in the top rows, well above the dropped zone.
  printf '%s\n' "$cur" | head -n "$((ROWS - 8))" | trim_trailing_blank
}

# Fix aha's output to match the real terminal:
#   * aha renders the 16 ANSI colors as bright CSS names (blue, purple, teal, …),
#     not the terminal palette — so tools that emit named ANSI (lazygit borders,
#     delta decorations) would look wrong. Remap each CSS name to the active
#     theme's palette hex. aha collapses normal/bright to one name, so bright maps
#     to the normal variant; its "dimgray" (both black variants) → muted grey,
#     since black text on a dark background would otherwise vanish.
#   * aha brightens bold text with `filter: contrast(70%) brightness(190%)`.
#     CSS `filter` also brightens the span's background-color, so a bold cell on
#     a selection band (lazygit's selected commit row) washes the band into a
#     pale bar and mutes the text — an artifact absent from the real terminal.
#     Strip every `filter:` declaration; the palette hexes are already correct.
ansi_remap() {
  sed -E \
    -e "s/:dimgray;/:${PAL_BRIGHT_BLACK};/g" \
    -e "s/:red;/:${PAL_RED};/g" \
    -e "s/:green;/:${PAL_GREEN};/g" \
    -e "s/:olive;/:${PAL_YELLOW};/g" \
    -e "s/:blue;/:${PAL_BLUE};/g" \
    -e "s/:purple;/:${PAL_MAGENTA};/g" \
    -e "s/:teal;/:${PAL_CYAN};/g" \
    -e "s/:gray;/:${PAL_WHITE};/g" \
    -e "s/:black;/:${PAL_BLACK};/g" \
    -e "s/filter:[^;]*;//g"
}

# Emit one full-width titled section: <label> + stdin ANSI as an HTML frame.
section() {
  local label=$1
  printf '<section><h2>%s</h2><pre class="frame">' "$label"
  aha --no-header | ansi_remap || true
  printf '</pre></section>\n'
}

# Emit one column of a per-file card: a small tool label + stdin ANSI frame.
# Used inside a <div class="cols"> so tools sit side by side for one file.
pane() {
  printf '<div class="pane"><h3>%s</h3><pre class="frame">' "$1"
  aha --no-header | ansi_remap || true
  printf '</pre></div>'
}

# quicklook column: highlight (the engine sbarex/QL uses) renders the file with
# the palette .theme straight to palette-hex HTML — no ANSI, so no remap. This
# reproduces QL's colors (not sbarex's exact layout) and is diffable, so it can
# live in the committed pages. stdin is highlight's HTML fragment.
ql_pane() {
  printf '<div class="pane"><h3>quicklook</h3><pre class="frame">'
  cat
  printf '</pre></div>'
}

# Pre-install treesitter parsers so none installs mid-capture — a parser
# installing shifts a sample from plain to highlighted between runs, and its
# progress messages vary. Best-effort; bounded wait. nvim-treesitter (main
# branch) installs async, so poll get_installed until the set is present.
prewarm_treesitter() {
  local langs="bash lua toml yaml json markdown markdown_inline go c_sharp xml css dockerfile python typescript tsx sql"
  echo "theme-gallery: ensuring treesitter parsers…" >&2
  nvim --headless \
    -c "lua local ts=require('nvim-treesitter'); local a=ts.get_available(); local w=vim.tbl_filter(function(p) return vim.tbl_contains(a,p) end, vim.split('$langs',' ')); ts.install(w); vim.wait(300000, function() local h=ts.get_installed('parsers'); for _,p in ipairs(w) do if not vim.tbl_contains(h,p) then return false end end; return true end, 300)" \
    -c 'qa!' >/dev/null 2>&1 || true
}

# Build an ephemeral git repo with a committed file plus working-tree add/
# change/delete edits, so gitsigns shows all three gutter signs and changed-line
# highlights (git_* + diff_*_bg). Prints the modified file's path. Deterministic.
make_gitsigns_fixture() {
  local dir
  dir="$(mktemp -d "${TMPDIR:-/tmp}/gitsigns-fixture.XXXXXX")"
  export GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null
  git init -q "$dir"
  git -C "$dir" config commit.gpgsign false
  git -C "$dir" config core.hooksPath /dev/null
  cat >"$dir/demo.lua" <<'BASE'
local M = {}
local x = 1
local y = 2
function M.sum()
  return x + y
end
return M
BASE
  git -C "$dir" add -A
  GIT_AUTHOR_NAME=demo GIT_AUTHOR_EMAIL=demo@example.com \
    GIT_COMMITTER_NAME=demo GIT_COMMITTER_EMAIL=demo@example.com \
    GIT_AUTHOR_DATE='2026-01-01T09:00:00' GIT_COMMITTER_DATE='2026-01-01T09:00:00' \
    git -C "$dir" commit -q -m base
  # Working-tree edits vs HEAD: change (line 2), add (new line), delete (last).
  cat >"$dir/demo.lua" <<'MOD'
local M = {}
local x = 10
local y = 2
local sum = 0
function M.sum()
  return x + y
end
MOD
  printf '%s\n' "$dir/demo.lua"
}

page_header() {
  local t=$1 bg=$2 fg=$3
  cat <<HTML
<!DOCTYPE html>
<!-- Generated by theme-gallery; do not edit by hand. Run \`theme-gallery\`. -->
<html lang="en">
<head>
<meta charset="utf-8">
<title>theme gallery — $t</title>
<style>
  body { background: $bg; color: $fg; font-family: ui-monospace, "SFMono-Regular", Menlo, monospace; margin: 0; padding: 1.5rem; }
  h1 { font-size: 1.1rem; font-weight: 600; }
  h2 { font-size: 0.8rem; font-weight: 600; opacity: 0.7; margin: 1.5rem 0 0.35rem; text-transform: lowercase; }
  h3 { font-size: 0.72rem; font-weight: 600; opacity: 0.5; margin: 0 0 0.3rem; text-transform: lowercase; }
  .cols { display: flex; gap: 1rem; align-items: flex-start; }
  .pane { flex: 1 1 0; min-width: 0; }
  .frame { border: 1px solid rgba(128,128,128,0.3); border-radius: 6px; padding: 0.75rem 1rem; overflow-x: auto; line-height: 1.35; white-space: pre; }
  pre { margin: 0; }
</style>
</head>
<body>
<h1>theme gallery — $t</h1>
HTML
}

build_theme() {
  local t=$1
  echo "theme-gallery: rendering $t" >&2
  theme "$t" >/dev/null

  local bg fg pal
  bg="$(chezmoi execute-template '{{ (index .themes .theme).ansi.background }}')"
  fg="$(chezmoi execute-template '{{ (index .themes .theme).ansi.foreground }}')"

  # ANSI palette hexes (globals) consumed by ansi_remap for this theme.
  pal="$(chezmoi execute-template '{{ with (index .themes .theme).ansi }}{{ .bright_black }} {{ .red }} {{ .green }} {{ .yellow }} {{ .blue }} {{ .magenta }} {{ .cyan }} {{ .white }} {{ .black }}{{ end }}')"
  read -r PAL_BRIGHT_BLACK PAL_RED PAL_GREEN PAL_YELLOW PAL_BLUE PAL_MAGENTA PAL_CYAN PAL_WHITE PAL_BLACK <<<"$pal"

  # Render the quicklook .theme for the active theme, so highlight renders with
  # the exact palette QL uses (the .tmpl reads the active `theme`). highlight
  # only treats a --config-file as a theme if it ends in .theme, so give it a
  # fixed name inside a temp dir.
  local qldir qltheme
  qldir="$(mktemp -d "${TMPDIR:-/tmp}/qltheme.XXXXXX")"
  qltheme="$qldir/palette.theme"
  chezmoi execute-template <"$(chezmoi source-path)/dot_config/syntax-highlight/Themes/palette.theme.tmpl" >"$qltheme"

  local page="$outdir/$t.html"
  {
    page_header "$t" "$bg" "$fg"

    # Per file: bat and nvim side by side, so the two renderings of the same
    # file can be compared directly (skip the diff; delta owns that). Diagnostics
    # are disabled for these syntax cards: a project-less sample (e.g. sample.tsx
    # with unresolvable react/JSX) would otherwise draw LSP error underlines, and
    # aha can't render colored undercurls (SGR 58) — they corrupt into a spurious
    # purple background. Semantic tokens still load; the showcase below owns
    # diagnostics.
    local f base
    for f in "$samples_dir"/*; do
      base="$(basename "$f")"
      [[ $base == sample.diff ]] && continue
      printf '<section class="card"><h2>%s</h2><div class="cols">' "$base"
      bat --color=always --style=plain --theme=palette "$f" 2>/dev/null | pane "bat"
      ncapture "$f" "$lib/no-diagnostics.lua" | pane "nvim"
      # highlight can fail on files whose syntax it can't detect (e.g.
      # extensionless Dockerfile); don't let that abort the gallery.
      highlight -O html --fragment --inline-css --config-file="$qltheme" -i "$f" 2>/dev/null | ql_pane || true
      printf '</div></section>\n'
    done

    # delta — the diff sample (full width; no bat/nvim counterpart).
    delta --paging=never <"$samples_dir/sample.diff" 2>/dev/null | section "delta — sample.diff"

    # bat -H line-highlight showcase — the ui.line_highlight band. The per-file
    # bat columns use --style=plain without -H, so this is the only place it shows.
    bat --color=always --style=plain --theme=palette -H 5 "$samples_dir/sample.go" 2>/dev/null | section "bat — line highlight (-H)"

    # nvim diagnostics showcase — one of each severity (diag_* palette).
    ncapture "$lib/diagnostics.txt" "$lib/diagnostics.lua" | section "nvim — diagnostics"

    # nvim gitsigns showcase — add/change/delete signs + line highlights
    # (git_* and diff_*_bg palette).
    local gs
    gs="$(make_gitsigns_fixture)"
    ncapture "$gs" "$lib/no-diagnostics.lua" | section "nvim — gitsigns (add/change/delete)"
    rm -rf "$(dirname "$gs")"

    # lazygit — branches (block 3) and commits (block 4), each fullscreened.
    local fixture
    fixture="$("$fixture_gen")"
    tcapture "lazygit -p '$fixture'" 2.5 3 + + | section "lazygit — branches"
    tcapture "lazygit -p '$fixture'" 2.5 4 + + | section "lazygit — commits"
    rm -rf "$fixture"

    printf '</body>\n</html>\n'
  } >"$page"
  rm -rf "$qldir"
  echo "theme-gallery: wrote $page" >&2
}

usage() {
  echo "Usage: theme-gallery"
  echo "  Renders docs/theme-gallery/<theme>.html for every palette theme,"
  echo "  each with bat | nvim | quicklook columns per file."
}

main() {
  case "${1:-}" in
    "") ;;
    -h | --help)
      usage
      return 0
      ;;
    *)
      usage >&2
      return 1
      ;;
  esac

  prewarm_treesitter

  local t
  while IFS= read -r t; do
    [[ -n $t ]] && build_theme "$t"
  done <<<"$(theme --list)"

  echo "theme-gallery: done. Open $outdir/*.html" >&2
}

main "$@"
