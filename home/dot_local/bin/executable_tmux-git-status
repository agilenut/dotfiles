#!/bin/bash
# Outputs: ⎇ branch-name [*] [⇡ahead] [⇣behind]
#   *      working tree has uncommitted changes (staged, unstaged, or untracked)
#   ⇡N   commits on HEAD not yet on any remote (unpushed; counts before the first push too)
#   ⇣N   commits on the upstream branch not yet pulled
# Prints nothing if not in a git repo.
#
# Usage: tmux-git-status [path]
# Pass the pane's current path so git runs in the right directory.

# Status-bar polling must never take .git/index.lock — a plain `git status`
# opportunistically writes the refreshed index, and this runs every 5s in the
# active pane's repo, colliding with commits happening there.
export GIT_OPTIONAL_LOCKS=0

if [ -n "$1" ]; then
  cd "$1" 2>/dev/null || exit 0
fi

# Branch name, or short SHA when detached; bail if not a repo.
branch=$(git symbolic-ref --short -q HEAD 2>/dev/null) \
  || branch=$(git rev-parse --short -q HEAD 2>/dev/null) \
  || exit 0

# Working tree dirty (any porcelain entry: staged, unstaged, or untracked)?
dirty=
[ -n "$(git status --porcelain 2>/dev/null)" ] && dirty=1

# Unpushed: commits on HEAD not reachable from any remote ref — works before the
# first push, unlike ahead-of-upstream. Skip when there is no remote (then
# --remotes matches nothing and the count would be every commit).
ahead=0
if [ -n "$(git remote 2>/dev/null)" ]; then
  ahead=$(git rev-list --count HEAD --not --remotes 2>/dev/null)
  [ -z "$ahead" ] && ahead=0
fi

# Behind: commits on the upstream not in HEAD (needs an upstream to compare to).
behind=$(git rev-list --count 'HEAD..@{upstream}' 2>/dev/null)
[ -z "$behind" ] && behind=0

# Branch in cyan; the dirty/sync indicators share one muted color (white) so red
# and yellow stay reserved for diagnostics elsewhere.
ind=white
out="#[fg=cyan]⎇ ${branch}"
[ -n "$dirty" ] && out+=" #[fg=${ind}]*"
[ "$ahead" -gt 0 ] && out+=" #[fg=${ind}]⇡${ahead}"
[ "$behind" -gt 0 ] && out+=" #[fg=${ind}]⇣${behind}"
echo "$out"
