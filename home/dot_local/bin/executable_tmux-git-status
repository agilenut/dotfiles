#!/bin/bash
# Outputs: ⎇ branch-name [+staged ~modified ?untracked]
# Or nothing if not in a git repo
#
# Usage: tmux-git-status [path]
# Pass the pane's current path so git runs in the right directory.

if [ -n "$1" ]; then
  cd "$1" 2>/dev/null || exit 0
fi

# One git call returns branch line + porcelain status; non-zero = not a repo.
status=$(git status --porcelain=v1 --branch 2>/dev/null) || exit 0

# One awk pass: parse branch from "## ..." line, count file statuses.
read -r branch staged modified untracked <<<"$(awk '
  NR == 1 {
    line = substr($0, 4)  # strip leading "## "
    if (line ~ /^No commits yet on /) {
      branch = substr(line, length("No commits yet on ") + 1)
    } else if (line ~ /\(no branch\)/) {
      branch = "HEAD"
    } else {
      sub(/\.\.\..*$/, "", line)  # strip "...upstream"
      sub(/ \[.*\]$/, "", line)   # strip " [ahead/behind]"
      branch = line
    }
    next
  }
  /^[MADRC]/ { staged++ }
  /^.[MD]/   { modified++ }
  /^\?\?/    { untracked++ }
  END { printf "%s %d %d %d", branch, staged+0, modified+0, untracked+0 }
' <<<"$status")"

[ -z "$branch" ] && exit 0

output="#[fg=cyan]⎇ ${branch}"

if [ "$staged" -gt 0 ] || [ "$modified" -gt 0 ] || [ "$untracked" -gt 0 ]; then
  output+=" #[fg=brightblack]["
  [ "$staged" -gt 0 ] && output+="#[fg=green]+${staged} "
  [ "$modified" -gt 0 ] && output+="#[fg=yellow]~${modified} "
  [ "$untracked" -gt 0 ] && output+="#[fg=red]?${untracked} "
  output="${output% }#[fg=brightblack]]"
fi

echo "$output"
