#!/bin/bash
# term-launch: open an Alacritty window attached to a named tmux session,
# surviving the cold-start restore race.
# Usage: term-launch <session> <config> <cwd> <title>
#
# The cold-start guard (boot a placeholder, wait for continuum's auto-restore
# to finish so resurrect's end-of-restore switch-client can't yank us onto the
# wrong session, ensure the target session exists) lives in tmux-coldstart,
# shared with the in-place tmux.zsh path. Here we just run it, then attach.

set -euo pipefail

session=$1
config=$2
cwd=$3
title=$4

"$HOME/.local/bin/tmux-coldstart" "$session"

exec open -na Alacritty --args \
  --config-file "$config" \
  --title "$title" \
  --working-directory "$cwd" \
  -e tmux attach -t "$session"
