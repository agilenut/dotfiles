#!/usr/bin/env bash
# Switch the active color theme by setting the runtime $THEME dial.
#
# Writes the global default to the state file .zshenv reads
# ($XDG_STATE_HOME/theme); new shells — and the tools they spawn (bat, delta,
# lazygit, nvim) — derive their theme from it. Repoints alacritty's current.toml
# and touches the configs so open windows live-reload their ANSI palette.
#
# Running shells keep their theme until a new shell starts (they read $THEME at
# startup). quicklook is a macOS GUI app whose selection is app state, so it also
# needs re-selecting in the Syntax Highlight app after a switch.
set -euo pipefail

cfgdir="${XDG_CONFIG_HOME:-$HOME/.config}"
statedir="${XDG_STATE_HOME:-$HOME/.local/state}"
statefile="$statedir/theme"
palette="$(dirname "$(chezmoi source-path)")/themes/palette.toml"

# Available themes = the [themes.<name>.ansi] tables in the palette.
themes=$(grep -oE '^\[themes\.[a-z0-9-]+\.ansi\]' "$palette" \
  | sed -E 's/.*themes\.([a-z0-9-]+)\.ansi.*/\1/')
current=$(cat "$statefile" 2>/dev/null || true)

usage() {
  echo "Usage: theme <name>"
  echo "Available:"
  echo "$themes" | sed 's/^/  /'
  [[ -n "$current" ]] && echo "Current: $current"
}

[[ $# -eq 1 ]] || {
  usage
  exit 1
}
if [[ "$1" == "--list" ]]; then
  echo "$themes"
  exit 0
fi
target=$1
echo "$themes" | grep -qxF "$target" || {
  echo "Unknown theme: $target"
  usage
  exit 1
}

# 1. Global default — the single token .zshenv reads. printf writes exactly one
#    line (no stray whitespace the derivation would carry into tool selectors).
mkdir -p "$statedir"
printf '%s\n' "$target" >"$statefile"

# 2. alacritty — repoint current.toml (the main config imports it) at the theme's
#    committed variant, then touch the top-level configs so open windows reload
#    (alacritty watches each window's primary config, not its imports).
themedir="$cfgdir/alacritty/themes"
if [[ -f "$themedir/$target.toml" ]]; then
  ln -sfn "$target.toml" "$themedir/current.toml"
  for a in "$cfgdir"/alacritty/*.toml; do
    [[ -f "$a" ]] && touch "$a"
  done
elif [[ -d "$themedir" ]]; then
  # alacritty is set up but this theme has no committed variant. Surface it
  # loudly rather than silently leaving alacritty (and likely bat/delta/lazygit,
  # whose selectors also key on the name) on the old theme — the palette and the
  # generated outputs are out of sync.
  echo "warning: no alacritty variant '$themedir/$target.toml' — run theme-gen" >&2
fi

# 3. quicklook (macOS) — sbarex renders the theme SELECTED in the Syntax
#    Highlight app, from a render cache that `qlmanage -r` does NOT clear (see
#    docs/known-issues.md). So copy the active theme onto the stable "current"
#    theme the app stays selected on (same idea as alacritty's current.toml),
#    then drop the render cache so the new colors actually show. Select "current"
#    in the app once; it follows every switch after that.
qldir="$HOME/Library/Application Support/Syntax Highlight/Themes"
qltheme="$cfgdir/syntax-highlight/Themes/$target.theme"
if [[ -d "$qldir" && -f "$qltheme" ]]; then
  # Write current.theme from the active theme but with Description="current", so
  # the app lists ONE stable "current" entry (the per-theme files keep their own
  # names). Reading + redirecting avoids sed -i's GNU/BSD portability split.
  sed 's/^Description=.*/Description="current"/' "$qltheme" >"$qldir/current.theme"
  rm -rf "$HOME/Library/Caches/org.sbarex.SourceCodeSyntaxHighlight/"* 2>/dev/null || true
  command -v qlmanage >/dev/null 2>&1 && qlmanage -r cache >/dev/null 2>&1 || true
fi

echo "theme set to: $target"
echo "Open a new shell/tab for bat/delta/lazygit/nvim to follow; alacritty reloaded."
