    ],
    "ask": [
      "Bash(brew install *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/create-worktree.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/remove-worktree.sh",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "autoUpdatesChannel": "stable",
  "theme": "dark-ansi"
}
