#!/usr/bin/env bash
# Rebuild bat's theme cache when the custom theme changes. bat reads a compiled
# cache (~/.cache/bat/themes.bin), not the .tmTheme directly, so a chezmoi apply
# that updates the theme needs this to take effect. delta reads bat's cached
# themes too, so this also refreshes git/lazygit diffs.
#
# The hashes below make chezmoi re-run this whenever the theme template, the
# palette, or the active theme selection changes (the last covers a `theme`
# toggle, where only the config value moves):
# tmpl:    {{ include "dot_config/bat/themes/palette.tmTheme.tmpl" | sha256sum }}
# palette: {{ include ".chezmoidata/themes.toml" | sha256sum }}
# active:  {{ if hasKey . "theme" }}{{ .theme }}{{ else }}vscode-dark-modern{{ end }}

set -euo pipefail

# bat is `batcat` on Debian/Ubuntu (binary-name clash). Skip silently if neither
# is installed — the cache is only relevant where bat exists.
if command -v bat >/dev/null 2>&1; then
  bat cache --build
elif command -v batcat >/dev/null 2>&1; then
  batcat cache --build
fi
