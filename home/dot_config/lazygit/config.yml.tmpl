{{- $name := "vscode-dark-modern" -}}
{{- if hasKey . "theme" }}{{ $name = .theme }}{{ end -}}
{{- $t := index .themes $name -}}
{{- if not $t }}{{ fail (printf "unknown theme %q" $name) }}{{ end -}}
promptToReturnFromSubprocess: false
os:
  editPreset: "nvim"
gui:
  sidePanelWidth: 0.25
  scrollHeight: 8
  nerdFontsVersion: "3"
  # Match delta's filename header (named ANSI blue) so accents share one palette.
  theme:
    activeBorderColor:
      - blue
    inactiveBorderColor:
      - "{{ $t.ui.muted }}"
    selectedLineBgColor:
      - "{{ $t.ui.selection }}"
    selectedRangeBgColor:
      - "{{ $t.ui.selection }}"
    optionsTextColor:
      - blue
  authorColors:
    "agilenut": blue # your commits in the theme blue
    "*": "{{ $t.ui.muted }}" # everyone else muted
  branchColorPatterns:
    "^feat/": "green"
    "^fix/": "red"
    "^refactor/": "magenta"
    "^perf/": "magenta"
    "^docs/": "blue"
    "^test/": "yellow"
    "^ci/": "cyan"
    "^build/": "cyan"
    "^chore/": "{{ $t.ui.dim }}"
    "^style/": "{{ $t.ui.dim }}"
git:
  diffContextSize: 10
{{- if lookPath "delta" }}
  pagers:
    - colorArg: always
      pager: delta --paging=never
{{- end }}
