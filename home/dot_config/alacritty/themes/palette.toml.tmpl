{{- $name := "vscode-dark-modern" -}}
{{- if hasKey . "theme" }}{{ $name = .theme }}{{ end -}}
{{- $t := index .themes $name -}}
{{- if not $t }}{{ fail (printf "unknown theme %q (see home/.chezmoidata/themes.toml)" $name) }}{{ end -}}
# Alacritty ANSI palette — generated from the active theme "{{ $name }}"
# (home/.chezmoidata/themes.toml). Do not edit by hand; run `theme <name>`.

[colors.primary]
  background = "{{ $t.ansi.background }}"
  foreground = "{{ $t.ansi.foreground }}"

[colors.normal]
  black   = "{{ $t.ansi.black }}"
  red     = "{{ $t.ansi.red }}"
  green   = "{{ $t.ansi.green }}"
  yellow  = "{{ $t.ansi.yellow }}"
  blue    = "{{ $t.ansi.blue }}"
  magenta = "{{ $t.ansi.magenta }}"
  cyan    = "{{ $t.ansi.cyan }}"
  white   = "{{ $t.ansi.white }}"

[colors.bright]
  black   = "{{ $t.ansi.bright_black }}"
  red     = "{{ $t.ansi.bright_red }}"
  green   = "{{ $t.ansi.bright_green }}"
  yellow  = "{{ $t.ansi.bright_yellow }}"
  blue    = "{{ $t.ansi.bright_blue }}"
  magenta = "{{ $t.ansi.bright_magenta }}"
  cyan    = "{{ $t.ansi.bright_cyan }}"
  white   = "{{ $t.ansi.bright_white }}"
