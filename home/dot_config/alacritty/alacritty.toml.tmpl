[general]

  # allow external commands to create new windows
  ipc_socket = true

  #import = ["~/.config/alacritty/themes/visual_studio_dark_plus.toml"]
  import = [ "~/.config/alacritty/themes/vscode_dark_modern.toml" ]

[env]
  TERM = "xterm-256color"

[terminal]
  # Silence "NSPasteboard#writeObjects: returned false" warns from OSC 52
  # writes (Claude Code emits these; tmux forwards). tmux copy bindings use
  # pbcopy directly, so disabling OSC 52 doesn't break explicit copies.
  osc52 = "Disabled"

[window]

  dynamic_title = true

  # maximized for laptop
  dimensions.columns = 180
  dimensions.lines   = 50
  position.x         = 0
  position.y         = 0

  # same dimentions as rectangle centered view
  #dimensions.columns = 147
  #dimensions.lines = 43
  #position.x = 175
  #position.y = 175

  padding.x = 10
  padding.y = 10

  decorations = "Buttonless"

  #opacity = 0.8
  blur = true

  option_as_alt = "Both"

[font]
  normal.family = "MesloLGS Nerd Font Mono"
  size          = 18

# URLs first so http(s)://… wins over the file-path regex on overlapping matches.
# `hyperlinks = true` also handles OSC 8 hyperlinks emitted by tools like `gh`.
# Schemes deliberately limited to web/email — `file:`, `git:`, `ssh:`, custom
# protocols (`slack:`, etc.) would let one click invoke arbitrary handlers.
[[hints.enabled]]
  regex           = '(?:https?|ftp|mailto):[^\s<>"`{}\[\]]+'
  command         = "open"
  hyperlinks      = true
  binding         = { key = "U", mods = "Control|Shift" }
  mouse           = { enabled = true, mods = "Command" }
  post_processing = true

[[hints.enabled]]
  # Match absolute (/foo), ~/foo, ./foo, ../foo, and repo-relative (home/foo) paths,
  # with optional :line[:col] suffix. Resolution happens in the open-path wrapper.
  regex           = "(?:~|\\.{1,2}|[\\w._+-]+)?/[\\w./_+-]+(?::\\d+(?::\\d+)?)?"
  command         = "{{ .chezmoi.homeDir }}/.local/bin/open-path"
  binding         = { key = "O", mods = "Control|Shift" }
  mouse           = { enabled = true, mods = "Command" }                         # Cmd+click triggers it
  post_processing = true
