{{- /* Resolve profile data - either from named profile or custom values */ -}}
{{- $name := "" -}}
{{- $email := "" -}}
{{- $signingkey := "" -}}

{{- if eq .profile "custom" -}}
{{-   $name = .github.name -}}
{{-   $email = .github.email -}}
{{-   if hasKey .github "signingkey" -}}
{{-     $signingkey = .github.signingkey -}}
{{-   end -}}
{{- else -}}
{{-   $p := index .profiles .profile -}}
{{-   $name = $p.github.name -}}
{{-   $email = $p.github.email -}}
{{-   if hasKey $p.github "signingkey" -}}
{{-     $signingkey = $p.github.signingkey -}}
{{-   end -}}
{{- end -}}

[user]
	name = {{ $name }}
	email = {{ $email }}
{{- if $signingkey }}
	signingkey = {{ $signingkey }}
{{- end }}

[core]
{{- if eq .chezmoi.os "windows" }}
	autocrlf = true
{{- else }}
	autocrlf = input
{{- end }}
{{- if lookPath "delta" }}
	pager = delta
{{- end }}

[init]
	defaultBranch = main

[status]
	short = true

[pull]
	rebase = false

[credential]
	helper =
	helper = manager

{{- if $signingkey }}
[gpg]
	format = ssh

[commit]
	gpgsign = true

{{- end }}
[credential "https://dev.azure.com"]
	useHttpPath = true

{{- if lookPath "delta" }}

[interactive]
	diffFilter = delta --color-only

{{- $name := "vscode-dark-modern" -}}
{{- if hasKey . "theme" }}{{ $name = .theme }}{{ end -}}
{{- $t := index .themes $name -}}
{{- if not $t }}{{ fail (printf "unknown theme %q" $name) }}{{ end }}
[delta]
	navigate = true
	line-numbers = true
	side-by-side = false
	; syntax-theme names the bat theme (regenerated per active theme), so
	; delta's foreground highlighting follows the toggle automatically.
	syntax-theme = palette
	; Muted diff backgrounds; `syntax` keeps foreground highlighting.
	; emph styles brighten the exact changed words within a line.
	plus-style = syntax "{{ $t.ui.diff_add_bg }}"
	minus-style = syntax "{{ $t.ui.diff_del_bg }}"
	plus-emph-style = syntax "{{ $t.ui.diff_add_emph_bg }}"
	minus-emph-style = syntax "{{ $t.ui.diff_del_emph_bg }}"
	; Calmer line-number gutter; muted tint instead of saturated green/red.
	line-numbers-plus-style = "{{ $t.ui.git_add }}"
	line-numbers-minus-style = "{{ $t.ui.git_delete }}"
	line-numbers-zero-style = "{{ $t.ui.muted }}"
{{- end }}

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default
